---
const { title = 'Família SOL na Estrada Real', desc = 'Diário de viagem da Família SOL: Brasília → Ouro Preto → Tiradentes → Paraty pelo Caminho Velho da Estrada Real.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content={desc}>
<title>{title}</title>
<link rel="stylesheet" href={base + 'styles.css'}>
</head>
<body>
<header class="top"><div class="in">
  <a class="logo" href={base}>☀️ Família SOL na Estrada Real</a>
  <nav class="menu">
    <a href={base}>Início</a>
    <a href={base + 'roteiro/'}>O Guia</a>
    <a href={base + 'custos/'}>Custos</a>
    <a href={base + 'sobre/'}>Sobre</a>
  </nav>
</div></header>
<div class="wrap">
  <slot />
</div>
<footer class="rodape">
  Família SOL ☀️ — Mário, Vicência, Helena e Maitê · Estrada Real, julho de 2026<br>
  Feito com Astro + GitHub Pages · fotos históricas: Wikimedia Commons (CC)
</footer>
</body>
</html>
