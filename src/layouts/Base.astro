---
const { title = 'Família SOL na Estrada Real', desc = 'Diário de viagem da Família SOL: Brasília → Ouro Preto → Tiradentes → Paraty pelo Caminho Velho da Estrada Real.' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content={desc}>
<title>{title}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href={base + 'styles.css'}>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>☀️</text></svg>">
</head>
<body>
<header class="top"><div class="in">
  <a class="logo" href={base}>☀️ Família <em>SOL</em> na Estrada Real</a>
  <nav class="menu">
    <a href={base}>Início</a>
    <a href={base + 'roteiro/'}>O Guia</a>
    <a href={base + 'custos/'}>Custos</a>
    <a href={base + 'sobre/'}>Sobre</a>
  </nav>
</div></header>
<slot name="hero" />
<div class="wrap">
  <slot />
</div>
<footer class="rodape">
  <span class="soldiv">☀️</span>
  <b>Família SOL</b> — Mário, Vicência, Helena e Maitê · Estrada Real, julho de 2026<br>
  3.050 km no rastro do ouro · feito com Astro + GitHub Pages · fotos históricas: Wikimedia Commons (CC)
</footer>
</body>
</html>
