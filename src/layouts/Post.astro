---
import Base from './Base.astro';
const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const slug = 'dia-' + String(frontmatter.dia).padStart(2,'0');
---
<Base title={frontmatter.title + ' · Família SOL na Estrada Real'}>
  <div class="postcover"><img src={base + 'fotos/' + slug + '/capa.jpg'} alt="" onerror="this.parentElement.remove()" /></div>
  <p style="margin-top:20px"><span class="selo">Dia {frontmatter.dia} · {frontmatter.data}</span></p>
  <h1>{frontmatter.title}</h1>
  <p class="meta">🛣️ {frontmatter.trajeto} · {frontmatter.km}</p>
  <article><slot /></article>
  <p style="margin-top:28px"><a class="btn" href={base}>← Todos os dias</a></p>
</Base>
