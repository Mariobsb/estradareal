---
import Base from '../layouts/Base.astro';
---
<Base title="Custos · Família SOL na Estrada Real">
  <h1>💰 Custos reais × planejado</h1>
  <p class="meta">Preencher na volta — o planejado veio do guia; o real, dos recibos fotografados.</p>
  <div class="card">
  <table>
    <tr><th>Categoria</th><th>Planejado</th><th>Real</th></tr>
    <tr><td>Combustível (~3.050 km)</td><td>R$ 2.070</td><td>✍️</td></tr>
    <tr><td>Pedágios</td><td>R$ 272</td><td>✍️</td></tr>
    <tr><td>Hospedagem (12 noites)</td><td>R$ 7.140</td><td>✍️</td></tr>
    <tr><td>Ingressos e passeios</td><td>R$ 1.650 + meias das meninas</td><td>✍️</td></tr>
    <tr><td>Alimentação</td><td>R$ 3.750</td><td>✍️</td></tr>
    <tr><td><b>Total</b></td><td><b>~R$ 15 mil</b></td><td>✍️</td></tr>
  </table>
  </div>
</Base>
