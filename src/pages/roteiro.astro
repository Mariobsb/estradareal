---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<Base title="O Guia · Família SOL na Estrada Real">
  <h1>🧭 O Guia da Expedição</h1>
  <p>O planejamento completo que usamos na estrada — rota dia a dia, história de cada lugar, missões das meninas, hotéis, restaurantes, custos e checklist. Funciona offline.</p>
  <p><a class="btn" href={base + 'guia.html'}>Abrir o Guia completo →</a></p>
</Base>
