---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const mods = import.meta.glob('./dias/*.md', { eager: true });
const dias = Object.values(mods).sort((a,b)=>a.frontmatter.dia-b.frontmatter.dia);
const rota = [
  ['Brasília','20/07',''],['Ouro Preto','20–23',''],['Congonhas','23/07',''],['S. J. del-Rei','23–24',''],
  ['Tiradentes','24–26',''],['Cunha','26–27',''],['Paraty','27–31','mar'],['Trindade','30/07','mar'],['Brasília','01/08','']
];
---
<Base>
  <section class="hero" slot="hero">
    <span class="sol">☀️</span>
    <span class="selo">Julho de 2026 · Caminho Velho da Estrada Real</span>
    <h1>A Família <em>SOL</em><br>no rastro do ouro</h1>
    <p class="sub">Mário, Vicência, Helena (11) e Maitê (7) — 3.050 km de Brasília a Paraty: minas de verdade, os 12 Profetas, uma maria-fumaça de 1881 e o mar no final.</p>
    <div class="cta">
      <a class="btn" href={base + 'dias/dia-01/'}>Começar pelo Dia 1 →</a>
      <a class="btn claro" href={base + 'roteiro/'}>🧭 O guia da expedição</a>
    </div>
  </section>

  <div class="rota">
    {rota.map(r => (<span class={'rstop ' + r[2]}><b>{r[0]}</b>{r[1]}</span>))}
  </div>

  <h2 class="sec">O diário de bordo</h2>
  <p class="lead">Treze dias, treze histórias — com as missões da Caçadora de Carimbos e as crônicas da Cronista-Chefe.</p>
  <div class="grid">
    {dias.map(d => {
      const slug = 'dia-' + String(d.frontmatter.dia).padStart(2,'0');
      return (
      <a class="dcard" href={base + 'dias/' + slug + '/'}>
        <span class="cover">
          <img src={base + 'fotos/' + slug + '/capa.jpg'} alt="" loading="lazy" onerror="this.remove()" />
          <span class="badge">Dia {d.frontmatter.dia} · {d.frontmatter.data}</span>
        </span>
        <span class="tx">
          <b>{d.frontmatter.title}</b>
          <span class="mut">🛣️ {d.frontmatter.trajeto}</span>
          <span class="ler">Ler o dia →</span>
        </span>
      </a>
    )})}
  </div>
</Base>
