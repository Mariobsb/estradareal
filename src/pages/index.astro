---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const mods = import.meta.glob('./dias/*.md', { eager: true });
const dias = Object.values(mods).sort((a,b)=>a.frontmatter.dia-b.frontmatter.dia);
---
<Base>
  <div style="text-align:center;padding:34px 0 10px">
    <span class="selo">☀️ Julho de 2026 · Caminho Velho</span>
    <h1>A Família <em style="color:var(--ouro2);font-style:normal">SOL</em> no rastro do ouro</h1>
    <p class="meta" style="max-width:560px;margin:0 auto">Mário, Vicência, Helena (11) e Maitê (7) — 3.050 km de Brasília a Paraty pela Estrada Real: minas, profetas, uma maria-fumaça de 1881 e o mar no final.</p>
  </div>

  <div class="card" style="text-align:center">
    🐴🔔 <b>13 dias, 13 histórias.</b> Acompanhe a expedição dia a dia — ou comece pelo <a href={base + 'roteiro/'}>guia completo</a> que planejou tudo isso.
  </div>

  <h2>📖 O diário de bordo</h2>
  <div class="grid">
    {dias.map(d => (
      <a class="dcard" href={base + 'dias/dia-' + String(d.frontmatter.dia).padStart(2,'0') + '/'}>
        <img src={base + 'fotos/dia-' + String(d.frontmatter.dia).padStart(2,'0') + '/capa.jpg'} alt="" onerror="this.style.display='none'" loading="lazy" />
        <span class="tx">
          <span class="num">Dia {d.frontmatter.dia} · {d.frontmatter.data}</span>
          <b>{d.frontmatter.title}</b>
          <span class="mut">{d.frontmatter.trajeto}</span>
        </span>
      </a>
    ))}
  </div>
</Base>
